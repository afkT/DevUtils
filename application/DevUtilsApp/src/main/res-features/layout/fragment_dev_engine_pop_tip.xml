<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <variable
            name="viewModel"
            type="afkt.project.features.dev_engine.PopTipViewModel" />
    </data>

    <androidx.core.widget.NestedScrollView style="@style/ViewTheme.NestedScrollView">

        <LinearLayout
            style="@style/ViewTheme.Padding.LR_DP_10"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatButton
                style="@style/ViewTheme.Button.Single"
                android:onClick="@{viewModel.clickShow}"
                android:text="show 默认 PopTip" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/ViewTheme.Button.Single"
                android:onClick="@{viewModel.clickShowSuccess}"
                android:text="show 成功状态 PopTip" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/ViewTheme.Button.Single"
                android:onClick="@{viewModel.clickShowWarning}"
                android:text="show 警告状态 PopTip" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/ViewTheme.Button.Single"
                android:onClick="@{viewModel.clickShowError}"
                android:text="show 错误状态 PopTip" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/ViewTheme.Button.Single"
                android:onClick="@{viewModel.clickShowButton}"
                android:text="show 含按钮 PopTip" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/ViewTheme.Button.Single"
                android:onClick="@{viewModel.clickShowAlignTop}"
                android:text="show 顶部对齐 PopTip" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/ViewTheme.Button.Single"
                android:onClick="@{viewModel.clickShowAlignBottom}"
                android:text="show 底部对齐 PopTip" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>