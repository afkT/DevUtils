<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- LinearLayout 基础样式 -->

    <style name="ViewTheme.LinearLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="ViewTheme.LinearLayout.Match">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="ViewTheme.LinearLayout.Match.Width">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="ViewTheme.LinearLayout.Match.Height">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <!-- LinearLayout 样式 -->

    <style name="ViewTheme.LinearLayout.Vertical" />

    <style name="ViewTheme.LinearLayout.Horizontal">
        <item name="android:orientation">horizontal</item>
    </style>

    <!-- LinearLayout 边距基础样式 -->

    <style name="ViewTheme.LinearLayout.Margin" />

    <style name="ViewTheme.LinearLayout.Padding" />

    <!-- ==================== -->
    <!-- LinearLayout Gravity -->
    <!-- ==================== -->

    <style name="ViewTheme.LinearLayout.Gravity" />

    <style name="ViewTheme.LinearLayout.Gravity.Layout" />

    <!-- CENTER -->

    <style name="ViewTheme.LinearLayout.Gravity.CENTER">
        <item name="android:gravity">center</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.CENTER_START">
        <item name="android:gravity">center|start</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.CENTER_TOP">
        <item name="android:gravity">center|top</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.CENTER_END">
        <item name="android:gravity">center|end</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.CENTER_BOTTOM">
        <item name="android:gravity">center|bottom</item>
    </style>

    <!-- START -->

    <style name="ViewTheme.LinearLayout.Gravity.START">
        <item name="android:gravity">start</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.START_TOP">
        <item name="android:gravity">start|top</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.START_BOTTOM">
        <item name="android:gravity">start|bottom</item>
    </style>

    <!-- END -->

    <style name="ViewTheme.LinearLayout.Gravity.END">
        <item name="android:gravity">end</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.END_TOP">
        <item name="android:gravity">end|top</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.END_BOTTOM">
        <item name="android:gravity">end|bottom</item>
    </style>

    <!-- CENTER_XXX -->

    <style name="ViewTheme.LinearLayout.Gravity.CENTER_VERTICAL">
        <!-- 等同于 center|start -->
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.CENTER_HORIZONTAL">
        <!-- 等同于 center|top -->
        <item name="android:gravity">center_horizontal</item>
    </style>

    <!-- LinearLayout Layout Gravity -->

    <!-- CENTER -->

    <style name="ViewTheme.LinearLayout.Gravity.Layout.CENTER">
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.CENTER_START">
        <item name="android:layout_gravity">center|start</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.CENTER_TOP">
        <item name="android:layout_gravity">center|top</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.CENTER_END">
        <item name="android:layout_gravity">center|end</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.CENTER_BOTTOM">
        <item name="android:layout_gravity">center|bottom</item>
    </style>

    <!-- START -->

    <style name="ViewTheme.LinearLayout.Gravity.Layout.START">
        <item name="android:layout_gravity">start</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.START_TOP">
        <item name="android:layout_gravity">start|top</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.START_BOTTOM">
        <item name="android:layout_gravity">start|bottom</item>
    </style>

    <!-- END -->

    <style name="ViewTheme.LinearLayout.Gravity.Layout.END">
        <item name="android:layout_gravity">end</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.END_TOP">
        <item name="android:layout_gravity">end|top</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.END_BOTTOM">
        <item name="android:layout_gravity">end|bottom</item>
    </style>

    <!-- CENTER_XXX -->

    <style name="ViewTheme.LinearLayout.Gravity.Layout.CENTER_VERTICAL">
        <!-- 等同于 center|start -->
        <item name="android:layout_gravity">center_vertical</item>
    </style>

    <style name="ViewTheme.LinearLayout.Gravity.Layout.CENTER_HORIZONTAL">
        <!-- 等同于 center|top -->
        <item name="android:layout_gravity">center_horizontal</item>
    </style>
</resources>