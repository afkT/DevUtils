<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- LinearLayout 基础样式 -->

    <style name="ViewTheme.LinearLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- LinearLayout 样式 -->

    <style name="ViewTheme.LinearLayout.Vertical" />

    <style name="ViewTheme.LinearLayout.Horizontal">
        <item name="android:orientation">horizontal</item>
    </style>

    <!-- LinearLayout 边距基础样式 -->

    <style name="ViewTheme.LinearLayout.Margin" />

    <style name="ViewTheme.LinearLayout.Padding" />

    <!--【内置】样式 -->

    <!-- LinearLayout 边距样式 -->

    <style name="ViewTheme.LinearLayout.Padding.TB_DP_10">
        <item name="android:paddingTop">10.0dp</item>
        <item name="android:paddingBottom">10.0dp</item>
    </style>

    <style name="ViewTheme.LinearLayout.Padding.LR_DP_10">
        <item name="android:paddingLeft">10.0dp</item>
        <item name="android:paddingRight">10.0dp</item>
    </style>

    <style name="ViewTheme.LinearLayout.Margin.TB_DP_10">
        <item name="android:layout_marginTop">10.0dp</item>
        <item name="android:layout_marginBottom">10.0dp</item>
    </style>

    <style name="ViewTheme.LinearLayout.Margin.LR_DP_10">
        <item name="android:layout_marginLeft">10.0dp</item>
        <item name="android:layout_marginRight">10.0dp</item>
    </style>
</resources>