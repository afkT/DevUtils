<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- View 基础样式 -->

    <style name="ViewTheme" />

    <style name="ViewTheme.View">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="ViewTheme.View.Match">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="ViewTheme.View.Match.Width">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="ViewTheme.View.Match.Height">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <!-- View 占位 -->

    <style name="ViewTheme.View.Space">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
    </style>

    <!-- View 弹性占位 -->

    <style name="ViewTheme.View.Space.Weight">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
    </style>

    <!-- ============ -->
    <!-- View Gravity -->
    <!-- ============ -->

    <style name="ViewTheme.View.Gravity" />

    <style name="ViewTheme.View.Gravity.Layout" />

    <!-- CENTER -->

    <style name="ViewTheme.View.Gravity.CENTER">
        <item name="android:gravity">center</item>
    </style>

    <style name="ViewTheme.View.Gravity.CENTER_START">
        <item name="android:gravity">center|start</item>
    </style>

    <style name="ViewTheme.View.Gravity.CENTER_TOP">
        <item name="android:gravity">center|top</item>
    </style>

    <style name="ViewTheme.View.Gravity.CENTER_END">
        <item name="android:gravity">center|end</item>
    </style>

    <style name="ViewTheme.View.Gravity.CENTER_BOTTOM">
        <item name="android:gravity">center|bottom</item>
    </style>

    <!-- START -->

    <style name="ViewTheme.View.Gravity.START">
        <item name="android:gravity">start</item>
    </style>

    <style name="ViewTheme.View.Gravity.START_TOP">
        <item name="android:gravity">start|top</item>
    </style>

    <style name="ViewTheme.View.Gravity.START_BOTTOM">
        <item name="android:gravity">start|bottom</item>
    </style>

    <!-- END -->

    <style name="ViewTheme.View.Gravity.END">
        <item name="android:gravity">end</item>
    </style>

    <style name="ViewTheme.View.Gravity.END_TOP">
        <item name="android:gravity">end|top</item>
    </style>

    <style name="ViewTheme.View.Gravity.END_BOTTOM">
        <item name="android:gravity">end|bottom</item>
    </style>

    <!-- CENTER_XXX -->

    <style name="ViewTheme.View.Gravity.CENTER_VERTICAL">
        <!-- 等同于 center|start -->
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="ViewTheme.View.Gravity.CENTER_HORIZONTAL">
        <!-- 等同于 center|top -->
        <item name="android:gravity">center_horizontal</item>
    </style>

    <!-- View Layout Gravity -->

    <!-- CENTER -->

    <style name="ViewTheme.View.Gravity.Layout.CENTER">
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.CENTER_START">
        <item name="android:layout_gravity">center|start</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.CENTER_TOP">
        <item name="android:layout_gravity">center|top</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.CENTER_END">
        <item name="android:layout_gravity">center|end</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.CENTER_BOTTOM">
        <item name="android:layout_gravity">center|bottom</item>
    </style>

    <!-- START -->

    <style name="ViewTheme.View.Gravity.Layout.START">
        <item name="android:layout_gravity">start</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.START_TOP">
        <item name="android:layout_gravity">start|top</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.START_BOTTOM">
        <item name="android:layout_gravity">start|bottom</item>
    </style>

    <!-- END -->

    <style name="ViewTheme.View.Gravity.Layout.END">
        <item name="android:layout_gravity">end</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.END_TOP">
        <item name="android:layout_gravity">end|top</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.END_BOTTOM">
        <item name="android:layout_gravity">end|bottom</item>
    </style>

    <!-- CENTER_XXX -->

    <style name="ViewTheme.View.Gravity.Layout.CENTER_VERTICAL">
        <!-- 等同于 center|start -->
        <item name="android:layout_gravity">center_vertical</item>
    </style>

    <style name="ViewTheme.View.Gravity.Layout.CENTER_HORIZONTAL">
        <!-- 等同于 center|top -->
        <item name="android:layout_gravity">center_horizontal</item>
    </style>
</resources>