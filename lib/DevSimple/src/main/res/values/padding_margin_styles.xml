    </style>

    <style name="ViewTheme.Margin.TB_DP_10">
        <item name="android:layout_marginTop">10.0dp</item>
        <item name="android:layout_marginBottom">10.0dp</item>
    </style>

    <style name="ViewTheme.Margin.LR_DP_10">
        <item name="android:layout_marginLeft">10.0dp</item>
